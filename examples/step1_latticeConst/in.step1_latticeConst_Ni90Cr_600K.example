# Step 1 example: lattice constant calculation for a NiCr alloy case
# This is a concrete manual example derived from the original template.
# The main public-facing change is the use of a relative potential-file path.

units           metal
dimension       3
boundary        p p p
atom_style      atomic

lattice         fcc 3.52
region          whole block 0 20 0 20 0 20 units lattice
create_box      2 whole
create_atoms    1 box

# Example composition: use NiFrac = 0.9
# With the original convention in this workflow, this is a Ni90Cr-like example.
set             type 1 type/fraction 2 0.9 722302

pair_style      eam/alloy
pair_coeff      * * ../../potentials/FeNiCr_ArturV3.eam Cr Ni

dump            1 all custom 1000 dump.afterCreate id type x y z
run 0
undump 1

neighbor        2.0 bin
neigh_modify    delay 10

fix             0 all box/relax iso 0.0 vmax 0.001
min_style       cg
minimize        1.0e-12 1.0e-12 2000 10000
unfix           0

reset_timestep  0
thermo          1000
thermo_style    custom step temp press pe lx ly lz pxx pyy pzz

timestep        0.001
velocity        all create 600 634534

fix             1 all npt temp 600 600 0.1 iso 0.0 0.0 1.0
run             50000

unfix           1
fix             2 all npt temp 600 600 0.1 iso 0.0 0.0 0.1

reset_timestep  0
variable        lx equal lx
variable        ly equal ly
variable        lz equal lz

fix             3 all ave/time 1 10000 10000 v_lx v_ly v_lz file lattice_constant.dat
run             50000

dump            1 all custom 1000 dump.afterMini id type x y z
run 0
undump 1
